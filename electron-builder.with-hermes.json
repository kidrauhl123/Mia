{
  "appId": "ai.mia.app",
  "productName": "Mia",
  "directories": {
    "output": "release"
  },
  "asar": true,
  "compression": "maximum",
  "publish": {
    "provider": "github",
    "owner": "kidrauhl123",
    "repo": "Mia"
  },
  "files": [
    "package.json",
    "packages/shared/**/*",
    "src/**/*",
    "resources/official-library/**/*",
    "resources/conductor/**/*",
    "!src/**/*.map",
    "!node_modules/@anthropic-ai/claude-agent-sdk-*-*/**",
    "!node_modules/@openai/codex-*-*/**"
  ],
  "extraResources": [
    {
      "from": "resources/pet-generator",
      "to": "pet-generator",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "skills",
      "to": "skills",
      "filter": [
        "**/*"
      ]
    }
  ],
  "mac": {
    "target": [
      "dir",
      "zip"
    ],
    "icon": "build/icon.icns",
    "category": "public.app-category.productivity",
    "identity": "XiaoChuan Technology Co., Ltd. (S4NWU843M5)",
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "extraResources": [
      {
        "from": "vendor/hermes-runtime/mac-arm64",
        "to": "hermes-runtime",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dmg": {
    "artifactName": "${productName}-${version}-Apple-Silicon.${ext}",
    "title": "${productName}",
    "sign": false,
    "writeUpdateInfo": false,
    "format": "ULFO",
    "background": "build/dmg-background.png",
    "iconSize": 96,
    "iconTextSize": 14,
    "window": {
      "width": 600,
      "height": 420
    },
    "contents": [
      {
        "x": 180,
        "y": 238,
        "type": "file"
      },
      {
        "x": 420,
        "y": 238,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "build/icon.ico",
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "extraResources": [
      {
        "from": "vendor/hermes-runtime/win-x64",
        "to": "hermes-runtime",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  },
  "extraMetadata": {
    "hermesBundled": true
  }
}
