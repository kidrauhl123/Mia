{
  "name": "mia",
  "version": "0.1.27",
  "private": true,
  "workspaces": [
    "apps/mobile-rn",
    "packages/shared"
  ],
  "productName": "Mia",
  "description": "Mia desktop demo with an app-owned Hermes runtime home.",
  "main": "src/main.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "open": "electron .",
    "start": "electron .",
    "web": "node scripts/serve-web.js",
    "cloud": "node scripts/serve-cloud.js",
    "cloud:release": "node scripts/build-cloud-release.js",
    "cloud:release:handoff": "node scripts/print-cloud-release-handoff.js",
    "cloud:release:handoff:file": "node scripts/print-cloud-release-handoff.js --write",
    "cloud:release:handoff:verify": "node scripts/print-cloud-release-handoff.js --verify-file",
    "cloud:release:handoff:bundle": "node scripts/print-cloud-release-handoff.js --bundle",
    "cloud:release:handoff:bundle:verify": "node scripts/print-cloud-release-handoff.js --verify-bundle",
    "cloud:blockers": "node scripts/print-cloud-blockers.js",
    "cloud:deploy:authorize-help": "node scripts/print-cloud-release-handoff.js --ssh-authorize",
    "cloud:deploy:ssh-diagnose": "node scripts/diagnose-deploy-ssh.js",
    "cloud:deploy": "bash scripts/deploy-cloud-release.sh",
    "cloud:deploy:dry-run": "MIA_DEPLOY_DRY_RUN=1 bash scripts/deploy-cloud-release.sh",
    "cloud:prod:verify": "node scripts/verify-cloud-production.js",
    "cloud:prod:verify:e2e": "MIA_SMOKE_REQUIRE_BRIDGE=1 node scripts/verify-cloud-production.js",
    "cloud:audit": "node scripts/audit-cloud-productization.js --live",
    "cloud:install:local": "bash scripts/install-cloud-release-local.sh",
    "cloud:install:verify": "MIA_INSTALL_VERIFY_ONLY=1 bash scripts/install-cloud-release-local.sh dist/mia-cloud-release.tgz",
    "cloud:doctor": "node scripts/doctor-cloud.js",
    "cloud:smoke": "node scripts/smoke-cloud.js",
    "cloud:site-verify": "node scripts/verify-site-verification.js",
    "cloud:skills:sync": "node scripts/sync-cloud-skills.js",
    "cloud:smoke:account": "node scripts/prepare-cloud-smoke-account.js",
    "managed:verify": "node scripts/verify-managed-agent-runtime.js",
    "desktop:permission-smoke": "node scripts/smoke-desktop-permission.js",
    "bridge": "node scripts/local-agent-bridge.js",
    "check": "node src/check.js",
    "clean:release": "node scripts/clean-release.js",
    "tidy:release": "node scripts/clean-release.js --tidy",
    "pack": "npm run clean:release && electron-builder --dir",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run clean:release && electron-builder --config electron-builder.mac-arm64.js --mac dir zip --arm64 --publish never && MIA_MAC_DMG_LABEL=Apple-Silicon node scripts/create-mac-dmg.js && npm run tidy:release",
    "dist:mac:intel": "npm run clean:release && electron-builder --config electron-builder.mac-intel.js --mac dir zip --x64 --publish never && MIA_MAC_DMG_LABEL=Intel node scripts/create-mac-dmg.js && npm run tidy:release",
    "dist:mac:x64": "npm run dist:mac:intel",
    "notarize:mac": "node scripts/notarize-mac-dmg.js Apple-Silicon",
    "notarize:mac:intel": "node scripts/notarize-mac-dmg.js Intel",
    "release:mac": "npm run dist:mac && node scripts/publish-mac-update.js",
    "release:mac:publish": "node scripts/publish-mac-update.js",
    "dist:win": "node scripts/build-win.js",
    "release:win": "npm run dist:win && node scripts/publish-win-update.js",
    "release:win:publish": "node scripts/publish-win-update.js"
  },
  "hermes": {
    "version": "2026.5.29",
    "pythonVersion": "3.11.13",
    "pbsRelease": "20251007"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.20.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.17",
    "cron-parser": "^4.9.0",
    "electron-updater": "^6.8.3",
    "gsap": "^3.15.0",
    "js-yaml": "^4.1.1",
    "qrcode": "^1.5.4",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "build": {
    "appId": "ai.mia.app",
    "productName": "Mia",
    "beforePack": "./scripts/stage-core-node.js",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "src/**",
      "packages/shared/**",
      "package.json",
      "resources/official-library/**",
      "node_modules/ws/**",
      "node_modules/zod/**",
      "node_modules/adm-zip/**",
      "node_modules/cron-parser/**",
      "node_modules/luxon/**",
      "node_modules/js-yaml/**",
      "node_modules/argparse/**",
      "node_modules/@agentclientprotocol/sdk/**",
      "node_modules/@anthropic-ai/claude-agent-sdk/**",
      "node_modules/@anthropic-ai/sdk/**",
      "node_modules/@modelcontextprotocol/sdk/**"
    ],
    "compression": "maximum",
    "publish": {
      "provider": "generic",
      "url": "https://mia.gifgif.cn/updates/"
    },
    "files": [
      "package.json",
      "packages/shared/**/*",
      "src/**/*",
      "resources/official-library/**/*",
      "resources/conductor/**/*",
      "!src/**/*.map",
      "!node_modules/@anthropic-ai/claude-agent-sdk-*-*/**"
    ],
    "extraResources": [
      {
        "from": "resources/mia-node/node",
        "to": "mia-node"
      },
      {
        "from": "node_modules/luxon",
        "to": "app.asar.unpacked/node_modules/luxon",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      },
      {
        "from": "resources/pet-generator",
        "to": "pet-generator",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "skills",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/managed-resources",
        "to": "managed-resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dir",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": "XiaoChuan Technology Co., Ltd. (S4NWU843M5)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "title": "${productName}",
      "sign": false,
      "writeUpdateInfo": false,
      "format": "ULFO",
      "background": "build/dmg-background.png",
      "iconSize": 96,
      "iconTextSize": 14,
      "window": {
        "width": 600,
        "height": 420
      },
      "contents": [
        {
          "x": 180,
          "y": 238,
          "type": "file"
        },
        {
          "x": 420,
          "y": 238,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
