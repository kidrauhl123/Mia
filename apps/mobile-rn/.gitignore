# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Firebase service-account keys (FCM push). NEVER commit — these are secrets.
# google-services.json is intentionally NOT ignored: it ships inside the APK and
# EAS cloud builds need it present in the repo.
*firebase-adminsdk*.json
*-service-account*.json
firebase-service-account*.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
